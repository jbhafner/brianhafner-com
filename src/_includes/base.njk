<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="/css/styles.css">
<link rel="canonical" href="https://brianhafner.com{{ canonical or page.url }}">
{% if noindex %}<meta name="robots" content="noindex">{% endif %}
{% if schema %}
<script type="application/ld+json">
{{ schema | dump | safe }}
</script>
{% endif %}
</head>
<body>

<header class="site-header">
  <div class="nav-row">
    <a href="/" class="wordmark">Brian <span>Hafner</span></a>
    <nav class="main-nav">
      <a href="/services/">Services</a>
      <a href="/case-studies/">Case Studies</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>
    <div class="nav-actions">
      <a href="/snapshot/" class="btn btn-primary">Get My Free AI Visibility Snapshot</a>
      <button class="nav-toggle" aria-label="Menu"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>

<main id="main">
{{ content | safe }}
</main>

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/" class="wordmark" style="color:#fff;">Brian <span>Hafner</span></a>
        <p style="margin-top:16px; max-width:320px;">AI Visibility consulting for service businesses. Know exactly how AI sees your brand, then fix it.</p>
      </div>
      <div>
        <h4>Site</h4>
        <ul>
          <li><a href="/services/">Services</a></li>
          <li><a href="/case-studies/">Case Studies</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:bh@brianhafner.com">bh@brianhafner.com</a></li>
          <li>San Diego, CA</li>
          <li><a href="https://brianhafner.info" rel="me">brianhafner.info →</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Brian Hafner Tech. I also write developer-focused notes at <a href="https://brianhafner.info" rel="me">brianhafner.info</a>.</span>
    </div>
  </div>
</footer>
<script src="/js/main.js"></script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function (user) {
      if (!user) {
        window.netlifyIdentity.on("login", function () {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
